# Copy to .env and fill in your Clerk values.
# Get these from https://dashboard.clerk.com → your app → API Keys.

# Used by docker-compose.yml (API service)
# Format: https://<your-clerk-domain>/.well-known/jwks.json
# Find it: Clerk dashboard → API Keys → scroll to "Advanced" → JWT verification endpoint
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
